<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CustomerManagement</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.*" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Exclude test project files from being compiled in the main project -->
    <Compile Remove="customer-management.Tests\**" />
    <Content Remove="customer-management.Tests\**" />
    <EmbeddedResource Remove="customer-management.Tests\**" />
    <None Remove="customer-management.Tests\**" />
  </ItemGroup>

</Project>
